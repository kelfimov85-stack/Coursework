<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:Coursework.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="Coursework.PageOneView"
             x:DataType="viewmodels:PageOne">

    <Border Background="#F8F9FA" Padding="20">
        <Grid RowDefinitions="Auto, *">
            
            <!-- ВЕРХНЯЯ ПАНЕЛЬ: Фильтры и статистика -->
            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="12" 
                    Padding="16" 
                    Margin="0,0,0,20"
                    BoxShadow="0 4 12 0 #0A000000">
                
                <Grid ColumnDefinitions="*, Auto, Auto, Auto" VerticalAlignment="Center">
                    
                    <!-- Поле поиска -->
                    <TextBox Grid.Column="0" 
                             Text="{Binding SearchText}" 
                             Watermark="🔍 Поиск по названию..." 
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             CornerRadius="8"
                             Height="40"/>
                    
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding SearchCategories}" 
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              CornerRadius="8"
                              Height="40"
                              MinWidth="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <ComboBox Grid.Column="2" 
                              ItemsSource="{Binding SortOptions}" 
                              SelectedItem="{Binding SortCategory}" 
                              Margin="0,0,16,0"
                              VerticalAlignment="Center"
                              CornerRadius="8"
                              Height="40"
                              MinWidth="150"/>
                    
                    <!-- Счётчик количества -->
                    <Border Grid.Column="3" 
                            Background="#E9ECEF" 
                            CornerRadius="20" 
                            Padding="14,8" 
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Найдено:" Foreground="#6C757D" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Count}" Foreground="#212529" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                </Grid>
            </Border>

            <!-- НИЖНЯЯ ПАНЕЛЬ: Список товаров -->
            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="12" 
                    Padding="8"
                    BoxShadow="0 4 12 0 #0A000000">
                
                <ListBox ItemsSource="{Binding Products}" 
                         Background="Transparent" 
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E9ECEF" 
                                    BorderThickness="0,0,0,1" 
                                    Padding="12,10"
                                    Margin="4,2">
                                
                                <Grid ColumnDefinitions="*, Auto">
                                    
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Name}" 
                                               FontSize="15" 
                                               FontWeight="SemiBold" 
                                               Foreground="#212529"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Price, StringFormat='{}{0:N2} ₽'}" 
                                               FontSize="16" 
                                               FontWeight="Bold" 
                                               Foreground="#0D6EFD" 
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"/>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            
        </Grid>
    </Border>
</UserControl>