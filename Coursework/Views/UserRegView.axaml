<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:compilerservices="using:System.Runtime.CompilerServices"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:metadata="using:Avalonia.Metadata"
             xmlns:viewsmodels="using:Coursework.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Coursework.UserRegView"
             x:DataType="viewsmodels:UserReg">
             
            <StackPanel Background="#8d9ce9" VerticalAlignment="Center" Width="800" Height="450">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Styles>
                        <Style Selector="TextBox">
                            <Setter Property="Margin" Value="35, 5, 35, 0"/>
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="FontWeight" Value="Black"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderBrush" Value="Black"/>
                        </Style>
                    </StackPanel.Styles>
				    <Image Margin="20, 20, 20, 0" Source="C:\Users\user\source\repos\Coursework\Coursework\Assets\User.jpg" Width="220" Height="100"/>
                    <TextBox Margin="35, 15, 35, 0" Watermark="FirstName" Text="{Binding FirstName}"/>
                    <TextBox Watermark="LastName" Text="{Binding LastName}"/>
                    <Button Content="Register" HorizontalAlignment="Center" Margin="0, 10" BorderThickness="0.5" BorderBrush="Black" Width="64" FontSize="12" Command="{Binding SaveNewUserCommand}"/>
                </StackPanel>
            </StackPanel>
</UserControl>