<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:compilerservices="using:System.Runtime.CompilerServices"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:metadata="using:Avalonia.Meatadata"
             xmlns:viewmodels="using:Coursework.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Coursework.PageForAddProductsView"
             x:DataType="viewmodels:PageForAddProducts">

    <StackPanel>
		<TextBox Watermark="Name" Text="{Binding NameNewProduct}"/>
		<TextBox Watermark="Price" Text="{Binding PriceNewProduct}"/>
		<TextBox Watermark="Quantity" Text="{Binding QuantityNewProduct}"/>
		<!-- <TextBox Watermark="Category" Text="{Binding CategoryNewProduct}"/> -->
        <Button Content="Save" Command="{Binding SaveNewProductCommand}"/>
    </StackPanel>

</UserControl>